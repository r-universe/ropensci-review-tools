[submodule ".registry"]
	path = .registry
	url = https://github.com/ropensci-review-tools/ropensci-review-tools.r-universe.dev
	branch = HEAD
[submodule "autotest"]
	path = autotest
	url = https://github.com/ropensci-review-tools/autotest
[submodule "babeldown"]
	path = babeldown
	url = https://github.com/ropensci-review-tools/babeldown
[submodule "babelquarto"]
	path = babelquarto
	url = https://github.com/ropensci-review-tools/autotest
[submodule "dashboard"]
	path = dashboard
	url = https://github.com/ropensci-review-tools/dashboard
[submodule "goodpractice"]
	path = goodpractice
	url = https://github.com/ropensci-review-tools/goodpractice
[submodule "orgmetrics"]
	path = orgmetrics
	url = https://github.com/ropensci-review-tools/orgmetrics
[submodule "pkgcheck"]
	path = pkgcheck
	url = https://github.com/ropensci-review-tools/pkgcheck
[submodule "pkgmatch"]
	path = pkgmatch
	url = https://github.com/ropensci-review-tools/pkgmatch
[submodule "pkgstats"]
	path = pkgstats
	url = https://github.com/ropensci-review-tools/pkgstats
[submodule "repometrics"]
	path = repometrics
	url = https://github.com/ropensci-review-tools/repometrics
[submodule "roreviewapi"]
	path = roreviewapi
	url = https://github.com/ropensci-review-tools/roreviewapi
[submodule "srr"]
	path = srr
	url = https://github.com/ropensci-review-tools/srr
